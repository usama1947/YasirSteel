@page "/"
@inject NavigationManager NavigationManager

<PageTitle>YasirSteel - Home</PageTitle>

<!-- Hero Section -->
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1>YasirSteel</h1>
            <p>Leading manufacturer of high-quality steel products and reinforcement solutions. Established as one of the most advanced fabrication facilities, specializing in Cut & Bend, Welded Wire Mesh, and Cold Rolled Wire products.</p>
            <a href="/contact" class="cta-button">Get Quote Now</a>
        </div>
    </div>
</section>

<!-- Quick About Section -->
<section class="page-section section-white">
    <div class="container">
        <div class="about-content">
            <div class="about-text">
                <h2>About YasirSteel</h2>
                <p>YasirSteel is a leading manufacturer of reinforcement steel products, operating one of the most advanced fabrication facilities in the region. Our state-of-the-art manufacturing processes ensure the highest quality standards.</p>
                <p>We specialize in manufacturing reinforcement steel products including Cut & Bend services, Welded Wire Mesh, and Cold Rolled Wire straightening & cutting solutions for the construction industry.</p>
                <a href="/about" class="cta-button" style="margin-top: 1rem;">Learn More</a>
            </div>
            <div class="about-stats">
                <div class="stat-item">
                    <div class="stat-number">150,000+</div>
                    <div class="stat-label">Tons Annual Capacity</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Projects Completed</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Expert Team Members</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Customer Support</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Preview -->
<section class="page-section section-gray">
    <div class="container">
        <h2 class="section-title">Our Services</h2>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">🔧</div>
                <h3>Cut & Bend Services</h3>
                <p>Precision cutting and bending of reinforcement steel bars according to international standards. Customized solutions for all construction requirements.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">🕸️</div>
                <h3>Welded Wire Mesh</h3>
                <p>High-quality welded wire mesh manufactured to meet international standards with rigorous quality control testing.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">⚙️</div>
                <h3>Cold Rolled Wire</h3>
                <p>Premium Cold Rolled Wire Products for extensive applications across various industries with highest quality standards.</p>
            </div>
        </div>
        <div style="text-align: center; margin-top: 3rem;">
            <a href="/services" class="cta-button">View All Services</a>
        </div>
    </div>
</section>

<!-- WhatsApp Floating Button -->
<div class="whatsapp-float">
    <a href="https://wa.me/+922112345678?text=Hello%20YasirSteel,%20I%20have%20a%20query%20about%20your%20products" target="_blank" class="whatsapp-button">
        <img src="/images/whatsapp-icon.png" alt="WhatsApp Chat" class="whatsapp-icon" />
        <span class="whatsapp-tooltip">Chat with us on WhatsApp</span>
    </a>
</div>

